{
  "name": "aifrobeats",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"wrangler dev\"",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply aifrobeats-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply aifrobeats-db --local",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wrangler": "^4.111.0"
  }
}
